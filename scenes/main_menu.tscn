[ext_resource type="Script" path="res://scenes/main_menu.gd" id="1_script"]

[sub_resource type="Shader" id="Shader_Grid"]
code = "shader_type spatial;

void fragment() {
    float grid_size = 1.0;
    float line_width = 0.05;
    vec2 grid = abs(fract(UV * 10.0 - 0.5) - 0.5) / line_width;
    float line = min(grid.x, grid.y);
    float mask = 1.0 - clamp(line, 0.0, 1.0);
    ALBEDO = vec3(0.2, 0.2, 0.2) + mask * vec3(0.1, 0.4, 0.1);
}"

